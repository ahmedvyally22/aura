# ==========================================
# AURA BOUTIQUE ENVIRONMENT CONFIGURATION
# ==========================================

# 🤖 Gemini AI API Config (Server-Side Secret)
# Get your Gemini API Key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# 🌐 Firebase Client Configuration (Client-Side Public Variables)
# Find these values in your Firebase Project Console -> Project Settings -> Web App Config
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"

# 🗄️ Firestore Database Config
# Specific database ID inside your Firestore. For 'default' database, use empty or 'default'
VITE_FIREBASE_FIRESTORE_DATABASE_ID="ai-studio-a53d10cb-6ce5-4b2a-a9b6-e977922002a0"
VITE_FIREBASE_MEASUREMENT_ID=""

# 🌍 Application Base URL
APP_URL="https://YOUR_APP_SUBDOMAIN.vercel.app"

